{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "tmux": {
      "command": "npx",
      "args": ["-y", "tmux-mcp"]
    },
    "deepwiki": {
      "type": "http",
      "url": "http://mcp.hurricane.home/mcp/Deepwiki-OSS",
      "headers": {
        "Authorization": "Bearer ${KRISHNA_PA_MCP_BEARER_TOKEN}"
      }
    },
    "internet-search": {
      "type": "http",
      "url": "http://mcp.hurricane.home/mcp/Internet-Search",
      "headers": {
        "Authorization": "Bearer ${KRISHNA_PA_MCP_BEARER_TOKEN}"
      }
    },
    "gitea": {
      "type": "http",
      "url": "http://mcp.hurricane.home/mcp/Gitea-Hurricane",
      "headers": {
        "Authorization": "Bearer ${KRISHNA_PA_MCP_BEARER_TOKEN}"
      }
    },
    "mewbo": {
      "type": "http",
      "url": "http://mcp.hurricane.home/mcp/Mewbo",
      "headers": {
        "Authorization": "Bearer ${KRISHNA_PA_MCP_BEARER_TOKEN}"
      }
    },
    "openalex": {
      "type": "http",
      "url": "https://openalex.caseyjhand.com/mcp"
    },
    "wikidata": {
      "type": "http",
      "url": "https://wd-mcp.wmcloud.org/mcp/"
    },
    "huggingface": {
      "type": "http",
      "url": "https://hf.co/mcp"
    },
    "gitmcp": {
      "type": "http",
      "url": "https://gitmcp.io/docs"
    }
  }
}
