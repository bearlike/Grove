# Grove — project-local config layer (machine-specific overrides)
.grove/config.local.json

# Grove — worktrees created under worktree.root_template (${repo}/.worktrees).
# Each is a linked git worktree (git tracks them via .git/worktrees/); ignore the
# checkout dir itself so the main repo's `git status` stays clean.
/.worktrees/

# Session-local working memory used by brainstorming → writing-plans →
# execution skills.  Never committed.
/docs/superpowers/specs
/docs/superpowers/plans

# Auto-generated by `make docs-schema`; source of truth is the Pydantic
# model in src/grove/core/config.py.
/docs/grove.schema.json

# Auto-generated by docs/hooks/schema_to_md.py at mkdocs build time.
/docs/configure-reference.md

# Claude Code state is local to each checkout and stays ignored, with a small
# allowlist of committed, publicly-served skills. The `!` lines only let git
# descend into `.claude/skills/`; `/.claude/skills/*` re-ignores every OTHER
# skill, so nothing else under .claude is committed. Add one `!` line per skill
# you want tracked.
/.claude/*
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/configuring-grove/
!/.claude/skills/reinstalling-grove/

# Webapp build + test artifacts
/webapp/node_modules
/webapp/.next
/webapp/coverage
/webapp/playwright-report
/webapp/test-results
/webapp/.env.local
# The Python `lib/` rule above (distutils build) sweeps up the webapp's
# source `lib/` directory. Negate it explicitly so source TS files are
# tracked. The Python build artifacts that the original rule targets
# never live under `/webapp/` anyway.
!/webapp/lib
!/webapp/lib/**
